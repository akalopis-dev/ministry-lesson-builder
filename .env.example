# Supabase project — from Project Settings → API. Use the service_role secret key,
# NEVER the anon/public key — this app talks to Supabase only from the server.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Shared team passcode gating the whole app (no personal logins).
WORKSPACE_CODE=

# Random secret used only to sign the session cookie — not shown to users.
SESSION_SECRET=
